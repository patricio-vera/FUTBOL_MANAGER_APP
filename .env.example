# =============================================================================
# SCOUTING & PERFORMANCE ANALYTICS HUB — Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a git (ya está en .gitignore).

# -----------------------------------------------------------------------------
# BASE DE DATOS — PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# SQL Server equivalente: "Server=host;Database=db;User Id=user;Password=pass;"
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/futbol_manager?schema=public"

# -----------------------------------------------------------------------------
# NEXTAUTH — Autenticación JWT
# NEXTAUTH_SECRET: clave secreta para firmar los JWT (mínimo 32 chars)
#   Generar con: openssl rand -base64 32
# NEXTAUTH_URL: URL base de la aplicación
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (opcional — para login social)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# JWT CONFIG (para el middleware RBAC custom)
# JWT_SECRET: misma clave que NEXTAUTH_SECRET o una separada para API tokens
# JWT_EXPIRY: expiración del token (ej. "7d", "24h", "30m")
# -----------------------------------------------------------------------------
JWT_SECRET="your-jwt-secret-for-api-tokens"
JWT_EXPIRY="7d"
